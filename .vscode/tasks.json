{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "label": "Backend (FastAPI)",
        "group": "RCSUMS",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Started.*$",
          "endsPattern": "^.*Uvicorn running.*$"
        }
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm run dev -- --host 127.0.0.1 --port 5173",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "label": "Frontend (Vite)",
        "group": "RCSUMS",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*vite.*$",
          "endsPattern": "^.*Local:.*5173.*$"
        }
      }
    },
    {
      "label": "Start Client Agent",
      "type": "shell",
      "command": "python sync.py",
      "options": {
        "cwd": "${workspaceFolder}/client-agent"
      },
      "presentation": {
        "label": "Client Agent",
        "group": "RCSUMS",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "🚀 Start RCSUMS (All Services)",
      "dependsOn": [
        "Start Backend",
        "Start Frontend",
        "Start Client Agent"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
